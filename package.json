{
  "name": "bridge-dashboard",
  "version": "1.0.0",
  "description": "Cross-chain bridge rate comparison dashboard backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "verify:db": "tsx scripts/verify-db.ts",
    "verify:fetcher": "tsx scripts/verify-fetcher.ts",
    "flush:db": "tsx scripts/flush-db.ts",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^8.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "pg": "^8.13.0",
    "pg-format": "^1.0.4",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^4.0.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
